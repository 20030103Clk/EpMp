<view class="container data-v-fa3ada11"><view class="header data-v-fa3ada11"><text class="title data-v-fa3ada11">质量管理</text></view><view class="quality-stats data-v-fa3ada11"><view class="stat-card data-v-fa3ada11"><text class="stat-title data-v-fa3ada11">合格率</text><text class="stat-value data-v-fa3ada11">{{a}}%</text></view><view class="stat-card data-v-fa3ada11"><text class="stat-title data-v-fa3ada11">检测数</text><text class="stat-value data-v-fa3ada11">{{b}}</text><text class="stat-unit data-v-fa3ada11">件</text></view><view class="stat-card data-v-fa3ada11"><text class="stat-title data-v-fa3ada11">合格数</text><text class="stat-value data-v-fa3ada11">{{c}}</text><text class="stat-unit data-v-fa3ada11">件</text></view></view><view class="inspection-section data-v-fa3ada11"><view class="section-header data-v-fa3ada11"><text class="section-title data-v-fa3ada11">质检记录</text></view><view class="inspection-list data-v-fa3ada11"><view wx:for="{{d}}" wx:for-item="item" wx:key="h" class="inspection-item data-v-fa3ada11"><view class="inspection-header data-v-fa3ada11"><text class="inspection-id data-v-fa3ada11">质检#{{item.a}}</text><text class="{{['inspection-result', 'data-v-fa3ada11', item.c]}}">{{item.b}}</text></view><view class="inspection-content data-v-fa3ada11"><view class="content-row data-v-fa3ada11"><text class="label data-v-fa3ada11">产品名称：</text><text class="value data-v-fa3ada11">{{item.d}}</text></view><view class="content-row data-v-fa3ada11"><text class="label data-v-fa3ada11">检测数量：</text><text class="value data-v-fa3ada11">{{item.e}} 件</text></view><view class="content-row data-v-fa3ada11"><text class="label data-v-fa3ada11">检测时间：</text><text class="value data-v-fa3ada11">{{item.f}}</text></view></view><view class="inspection-actions data-v-fa3ada11"><button class="delete-btn data-v-fa3ada11" bindtap="{{item.g}}">删除</button></view></view></view></view><view class="quality-actions data-v-fa3ada11"><button class="action-btn data-v-fa3ada11" bindtap="{{e}}">新建质检</button><button class="action-btn secondary data-v-fa3ada11" bindtap="{{f}}">质量报告</button></view><uni-popup class="r data-v-fa3ada11" u-s="{{['d']}}" u-r="newInspectionPopup" u-i="fa3ada11-0" bind:__l="__l"><view class="simple-popup data-v-fa3ada11"><view class="popup-title data-v-fa3ada11">新建质检</view><view class="popup-content data-v-fa3ada11"><view class="form-item data-v-fa3ada11"><text class="form-label data-v-fa3ada11">产品名称</text><input type="text" class="form-input data-v-fa3ada11" placeholder="请输入产品名称" value="{{g}}" bindinput="{{h}}"/></view><view class="form-item data-v-fa3ada11"><text class="form-label data-v-fa3ada11">检测数量</text><input type="number" class="form-input data-v-fa3ada11" placeholder="请输入数量" value="{{i}}" bindinput="{{j}}"/></view><view class="form-item data-v-fa3ada11"><text class="form-label data-v-fa3ada11">检测结果</text><radio-group class="data-v-fa3ada11" value="{{k}}" bindchange="{{l}}"><label class="data-v-fa3ada11"><radio class="data-v-fa3ada11" value="pass"/> 合格</label><label class="data-v-fa3ada11"><radio class="data-v-fa3ada11" value="fail"/> 不合格</label></radio-group></view></view><view class="popup-buttons data-v-fa3ada11"><button class="data-v-fa3ada11" type="default" bindtap="{{m}}">取消</button><button type="primary" class="confirm-btn data-v-fa3ada11" bindtap="{{n}}">确定</button></view></view></uni-popup><uni-popup class="r data-v-fa3ada11" u-s="{{['d']}}" u-r="qualityReportPopup" u-i="fa3ada11-1" bind:__l="__l"><view class="simple-popup data-v-fa3ada11"><view class="popup-title data-v-fa3ada11">质量报告</view><view class="popup-content data-v-fa3ada11"><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">报告名称</text><text class="report-value data-v-fa3ada11">{{p}}质检报告</text></view><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">检测数量</text><text class="report-value data-v-fa3ada11">{{q}} 件</text></view><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">合格数量</text><text class="report-value data-v-fa3ada11">{{r}} 件</text></view><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">合格率</text><text class="report-value highlight data-v-fa3ada11">{{s}}%</text></view></view><view class="popup-buttons data-v-fa3ada11"><button type="primary" class="report-close-btn data-v-fa3ada11" bindtap="{{t}}">关闭</button></view></view></uni-popup></view>