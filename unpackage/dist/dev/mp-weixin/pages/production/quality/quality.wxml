<view class="container data-v-fa3ada11"><view class="header data-v-fa3ada11"><text class="title data-v-fa3ada11">质量管理</text></view><view class="quality-stats data-v-fa3ada11"><view class="stat-card data-v-fa3ada11"><text class="stat-title data-v-fa3ada11">合格率</text><text class="stat-value data-v-fa3ada11">{{a}}%</text></view><view class="stat-card data-v-fa3ada11"><text class="stat-title data-v-fa3ada11">检测数</text><text class="stat-value data-v-fa3ada11">{{b}}</text><text class="stat-unit data-v-fa3ada11">件</text></view><view class="stat-card data-v-fa3ada11"><text class="stat-title data-v-fa3ada11">合格数</text><text class="stat-value data-v-fa3ada11">{{c}}</text><text class="stat-unit data-v-fa3ada11">件</text></view><view class="stat-card data-v-fa3ada11"><text class="stat-title data-v-fa3ada11">不合格数</text><text class="stat-value data-v-fa3ada11">{{d}}</text><text class="stat-unit data-v-fa3ada11">件</text></view></view><view class="inspection-section data-v-fa3ada11"><view class="section-header data-v-fa3ada11"><text class="section-title data-v-fa3ada11">质检记录</text></view><view class="inspection-list data-v-fa3ada11"><view wx:for="{{e}}" wx:for-item="item" wx:key="h" class="inspection-item data-v-fa3ada11"><view class="inspection-header data-v-fa3ada11"><text class="inspection-id data-v-fa3ada11">质检#{{item.a}}</text><text class="{{['inspection-result', 'data-v-fa3ada11', item.c]}}">{{item.b}}</text></view><view class="inspection-content data-v-fa3ada11"><view class="content-row data-v-fa3ada11"><text class="label data-v-fa3ada11">产品名称：</text><text class="value data-v-fa3ada11">{{item.d}}</text></view><view class="content-row data-v-fa3ada11"><text class="label data-v-fa3ada11">检测数量：</text><text class="value data-v-fa3ada11">{{item.e}} 件</text></view><view class="content-row data-v-fa3ada11"><text class="label data-v-fa3ada11">检测时间：</text><text class="value data-v-fa3ada11">{{item.f}}</text></view></view><view class="inspection-actions data-v-fa3ada11"><button wx:if="{{f}}" class="delete-btn data-v-fa3ada11" bindtap="{{item.g}}">删除</button></view></view></view></view><view class="quality-actions data-v-fa3ada11"><button class="action-btn secondary data-v-fa3ada11" bindtap="{{g}}">质量报告</button></view><uni-popup class="r data-v-fa3ada11" u-s="{{['d']}}" u-r="qualityReportPopup" u-i="fa3ada11-0" bind:__l="__l"><view class="simple-popup data-v-fa3ada11"><view class="popup-title data-v-fa3ada11">质量报告</view><view class="popup-content data-v-fa3ada11"><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">报告名称</text><text class="report-value data-v-fa3ada11">{{h}}质检报告</text></view><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">检测数量</text><text class="report-value data-v-fa3ada11">{{i}} 件</text></view><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">合格数量</text><text class="report-value data-v-fa3ada11">{{j}} 件</text></view><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">不合格数量</text><text class="report-value data-v-fa3ada11">{{k}} 件</text></view><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">合格率</text><text class="report-value highlight data-v-fa3ada11">{{l}}%</text></view><view class="report-item data-v-fa3ada11"><text class="report-label data-v-fa3ada11">按产品分类不合格数量</text><view class="unqual-by-product data-v-fa3ada11"><view wx:for="{{m}}" wx:for-item="item" wx:key="c" class="unqual-item data-v-fa3ada11"><text class="unqual-product data-v-fa3ada11">{{item.a}}</text><text class="unqual-quantity data-v-fa3ada11">{{item.b}} 件</text></view><view wx:if="{{n}}" class="no-data data-v-fa3ada11"><text class="data-v-fa3ada11">暂无不合格数据</text></view></view></view></view><view class="popup-buttons data-v-fa3ada11"><button type="primary" class="report-close-btn data-v-fa3ada11" bindtap="{{o}}">关闭</button></view></view></uni-popup></view>