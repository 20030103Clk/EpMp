<view class="record-page data-v-0c295e82"><view class="page-header data-v-0c295e82"><text class="page-title data-v-0c295e82">生产记录</text></view><view class="filter-section data-v-0c295e82"><view class="filter-row data-v-0c295e82"><view class="filter-item data-v-0c295e82"><text class="filter-label data-v-0c295e82">产品名称</text><input type="text" class="filter-input data-v-0c295e82" placeholder="请输入产品名称" value="{{a}}" bindinput="{{b}}"/></view><view class="filter-item data-v-0c295e82"><text class="filter-label data-v-0c295e82">使用设备</text><picker class="filter-picker data-v-0c295e82" bindchange="{{d}}" value="{{e}}" range="{{f}}" range-key="{{'name'}}"><view class="picker-value data-v-0c295e82">{{c}}</view></picker></view></view><view class="filter-row data-v-0c295e82"><view class="filter-item data-v-0c295e82"><text class="filter-label data-v-0c295e82">上报日期</text><picker class="filter-picker data-v-0c295e82" mode="date" value="{{h}}" bindchange="{{i}}"><view class="picker-value data-v-0c295e82">{{g}}</view></picker></view><view class="filter-actions data-v-0c295e82"><button class="filter-btn search data-v-0c295e82" bindtap="{{j}}">查询</button><button class="filter-btn reset data-v-0c295e82" bindtap="{{k}}">重置</button></view></view></view><view class="section data-v-0c295e82"><view class="section-header data-v-0c295e82"><text class="section-title data-v-0c295e82">产量上报记录</text><text class="record-count data-v-0c295e82">共 {{l}} 条记录</text></view><view class="record-list data-v-0c295e82"><view wx:for="{{m}}" wx:for-item="record" wx:key="e" class="record-item data-v-0c295e82"><view class="record-row main-info data-v-0c295e82"><text class="record-field product data-v-0c295e82">{{record.a}}</text><text class="record-field equipment data-v-0c295e82">{{record.b}}</text></view><view class="record-row secondary-info data-v-0c295e82"><text class="record-field time data-v-0c295e82">{{record.c}}</text><text class="record-field operator data-v-0c295e82">{{record.d}}</text></view></view><view wx:if="{{n}}" class="empty-state data-v-0c295e82"><text class="empty-text data-v-0c295e82">暂无生产记录</text></view></view></view></view>